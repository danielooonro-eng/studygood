# ============================================
# CRITICAL - Database Configuration (Required)
# ============================================
# Database URL (PostgreSQL with Supabase)
# Replace with your own Supabase PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.XXX.supabase.co:5432/postgres"

# ============================================
# Authentication Configuration (Required)
# ============================================
# JWT Secret for token signing (Change this in production!)
# Generate a strong random string for production
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ============================================
# API Configuration (Required)
# ============================================
# Next.js Public API URL
# Used for API calls from the frontend
NEXT_PUBLIC_API_URL="http://localhost:3000"

# ============================================
# Node Environment (Optional)
# ============================================
# Set to 'development', 'production', or 'test'
NODE_ENV="development"

# ============================================
# AI Service Configuration (Optional)
# ============================================
# Abacus AI API Key
# Used for advanced AI features (summarization, Q&A)
# If not set, the app will use fallback responses
# Get your API key from: https://www.abacus.ai/
ABACUS_API_KEY="your-abacus-ai-api-key-here"

# Abacus AI API Endpoint (Optional)
# Only needed if using a custom Abacus AI endpoint
# Default endpoints are tried automatically
# ABACUS_API_ENDPOINT="https://api.abacus.ai/v1/chat/completions"
